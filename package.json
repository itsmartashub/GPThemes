{
	"name": "gpthemes",
	"version": "6.7.6",
	"displayName": "GPThemes - ChatGPT Customization & Tweaks",
	"description": "Customize ChatGPT with themes, fonts, colors, layout widths, chatbox tweaks, and a floating settings dock.",
	"repository": {
		"type": "git",
		"url": "https://github.com/ronchak/GPThemes.git"
	},
	"bugs": {
		"url": "https://github.com/ronchak/GPThemes/issues"
	},
	"homepage": "https://github.com/ronchak/GPThemes/",
	"type": "module",
	"scripts": {
		"clean:dev": "node scripts/clean.js dev",
		"clean:prod": "node scripts/clean.js prod",
		"clean:zips": "node scripts/clean.js releases",
		"clean:all": "node scripts/clean.js all",
		"dev:chrome": "parcel watch src/manifests/chromium-mv3/manifest.json --dist-dir build/dev/chromium-mv3 --no-hmr",
		"dev:ff": "parcel watch src/manifests/firefox-mv2/manifest.json --dist-dir build/dev/firefox-mv2 --no-hmr",
		"build:chrome": "parcel build src/manifests/chromium-mv3/manifest.json --dist-dir build/prod/gpthemes-chromium-mv3 --no-source-maps",
		"build:ff": "parcel build src/manifests/firefox-mv2/manifest.json --dist-dir build/prod/gpthemes-firefox-mv2 --no-source-maps",
		"zip": "deno run --allow-read --allow-write --allow-env scripts/zip.js",
		"build:all": "pnpm clean:all && pnpm build:chrome && pnpm build:ff && pnpm zip",
		"lint": "biome lint",
		"lint:staged": "biome lint --staged",
		"format": "biome format --write",
		"check": "biome check --write",
		"check:max": "biome check --write --max-diagnostics=6000",
		"slint": "stylelint \"src/**/*.scss\"",
		"slint:fix": "stylelint \"src/**/*.scss\" --fix",
		"check:cycles": "node scripts/check-import-cycles.js",
		"test:runtime": "node --test tests/*.test.mjs",
		"validate": "pnpm lint && pnpm check:cycles && pnpm test:runtime && pnpm slint && pnpm build:all"
	},
	"author": "itsmarta",
	"keywords": [
		"chatgpt",
		"chatgpt-4o",
		"chatgpt-3.5",
		"openai",
		"gpt",
		"gpt-4o",
		"gpt-3.5",
		"ai",
		"chat",
		"chat bubbles",
		"gpt conversation",
		"themes",
		"chatgpt themes",
		"custom accent colours",
		"custom design",
		"custom fonts",
		"custom theming",
		"custom css",
		"theme enhancement",
		"ui customization",
		"style",
		"style chatgpt",
		"chatgpt themes",
		"chatgpt enhancement",
		"modern themes",
		"minimalistic",
		"gpthemes",
		"modern ui",
		"visual experience",
		"user interface makeover",
		"personalization",
		"customization",
		"stylish design",
		"refreshed appearance",
		"visual upgrade",
		"user-friendly",
		"css injection",
		"web design makeover",
		"plugin",
		"addon",
		"extension",
		"browser extension",
		"chrome",
		"chrome extension",
		"chrome web store",
		"firefox",
		"firefox addons",
		"foss",
		"opensource"
	],
	"browserslist": [
		"chrome >= 119",
		"edge >= 119",
		"firefox >= 128",
		"safari >= 18",
		"not dead"
	],
	"@parcel/bundler-default": {
		"disableSharedBundles": true
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@parcel/config-default": "^2.16.3",
		"@parcel/config-webextension": "^2.16.3",
		"@parcel/transformer-sass": "2.16.3",
		"autoprefixer": "^10.5.0",
		"parcel": "^2.16.3",
		"postcss": "^8.5.6",
		"stylelint": "^16.26.1",
		"stylelint-config-standard-scss": "^16.0.0"
	},
	"dependencies": {
		"webextension-polyfill": "^0.12.0"
	},
	"packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
	"private": true,
	"maintainers": [
		"ronchak"
	],
	"engines": {
		"node": ">=24",
		"pnpm": ">=11.2.2 <12"
	}
}
