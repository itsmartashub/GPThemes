{
	"manifest_version": 2,
	"version": "6.7.6.7",
	"name": "GPThemes (Ronak's Version)",
	"description": "Customize ChatGPT with themes, fonts, colors, layout widths, chatbox tweaks, and a floating settings dock.",
	"author": "itsmarta",
	"homepage_url": "https://github.com/itsmartashub/GPThemes",
	"icons": {
		"16": "../../assets/icons/16.png",
		"48": "../../assets/icons/48.png",
		"128": "../../assets/icons/128.png"
	},
	"content_scripts": [
		{
			"matches": [
				"https://chat.openai.com/*",
				"https://chatgpt.com/*"
			],
			"js": [
				"../../js/inject-theme.js"
			],
			"run_at": "document_start"
		},
		{
			"matches": [
				"https://chat.openai.com/*",
				"https://chatgpt.com/*"
			],
			"js": [
				"../../js/content.js"
			],
			"css": [
				"../../sass/index.scss"
			],
			"run_at": "document_idle"
		}
	],
	"permissions": [
		"storage",
		"https://chat.openai.com/*",
		"https://chatgpt.com/*"
	],
	"web_accessible_resources": [
		"../../assets/fonts/NOTICE.md",
		"../../assets/fonts/licenses/*.txt",
		"../../assets/fonts/files/*.woff2",
		"../../js/app/custom-fonts/generated/*.generated.txt",
		"*.png"
	],
	"browser_specific_settings": {
		"gecko": {
			"id": "gpthemes@itsmarta",
			"strict_min_version": "128.0",
			"data_collection_permissions": {
				"required": [
					"none"
				]
			}
		}
	},
	"background": {
		"scripts": [
			"../../js/background/index.js"
		],
		"persistent": false
	},
	"content_security_policy": "script-src 'self'; style-src 'self'; font-src 'self';",
	"browser_action": {
		"default_popup": "../../popup/popup.html",
		"default_icon": {
			"16": "../../assets/icons/16.png",
			"48": "../../assets/icons/48.png",
			"128": "../../assets/icons/128.png"
		},
		"default_title": "GPThemes (Ronak's Version)"
	}
}
